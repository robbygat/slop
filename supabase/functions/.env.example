# SLOP.game edge-function secrets — set these with the Supabase CLI:
#   supabase secrets set --env-file supabase/functions/.env
# or one at a time:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# …or in the Dashboard → Project → Edge Functions → Manage secrets.
#
# NONE of these belong in the repo or the browser. This file is a template only —
# copy it to supabase/functions/.env (gitignored), fill it in, and never commit it.

# ---- LLM providers (the keys your subscribers' usage runs on) ----
XAI_API_KEY=            # console.x.ai  (Grok chat + grok-imagine sprites)
OPENAI_API_KEY=         # platform.openai.com/api-keys  (GPT models)
ANTHROPIC_API_KEY=      # console.anthropic.com  (Claude models)

# ---- Stripe ----
STRIPE_SECRET_KEY=          # dashboard.stripe.com/apikeys  (sk_live_… or sk_test_…)
STRIPE_WEBHOOK_SECRET=      # from the webhook endpoint you create (whsec_…)
STRIPE_PRICE_PRO=           # price_… — the $5/mo recurring Price
STRIPE_PRICE_TOPUP_SMALL=   # price_… — one-time, ~$5 (600 credits)
STRIPE_PRICE_TOPUP_LARGE=   # price_… — one-time, ~$20 (3000 credits)

# ---- misc ----
SITE_URL=https://slop.game   # used for Stripe success/cancel redirects

# NOTE: SUPABASE_URL, SUPABASE_ANON_KEY, and SUPABASE_SERVICE_ROLE_KEY are injected
# into edge functions automatically — do NOT set them here.
